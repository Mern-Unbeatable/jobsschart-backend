generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  CONSULTANT
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING
}

enum OnlineStatus {
  ONLINE
  OFFLINE
  BUSY
}

enum CallType {
  PHONE
  VIDEO
  CHAT
}

enum CallStatus {
  PENDING
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum TransactionType {
  PURCHASE
  CALL_DEDUCTION
  REFUND
  BONUS
  ADJUSTMENT
}

enum TopicStatus {
  OPEN
  CLOSED
  PINNED
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum NotificationType {
  CALL_INCOMING
  CALL_ENDED
  CREDIT_LOW
  CREDIT_PURCHASED
  PAYOUT_PROCESSED
  MESSAGE_RECEIVED
  SYSTEM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AdStatus {
  PENDING
  ACTIVE
  PAUSED
  REJECTED
  EXPIRED
}

enum DonorType {
  INDIVIDUAL
  BUSINESS
}

enum AdPlacement {
  HOME
  CONSULTATION
  DONATION
  WEBSHOP
  GLOBAL
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentType {
  PACKAGE
  DONATION
  WEBSHOP
}

enum PaymentStatus {
  PENDING
  SUCCESS
}

enum PostType {
  THOUGHT
  QUESTION
  ANSWER
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ConversationType {
  DIRECT
  SUPPORT
  CONSULT
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

enum SessionType {
  AUDIO
  VIDEO
  CHAT
}

enum TicketStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum SupportMessageType {
  QUESTION
  ANSWER
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

